<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" 
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
    <Package Name="GrubStation" 
             Language="1033" 
             Version="$(var.Version)" 
             Manufacturer="Jeremy Jack" 
             UpgradeCode="2e8b9308-466d-4952-9d33-4f9342718712">
        
        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <!-- UI Configuration: Allow user to select installation directory, but skip the EULA -->
        <UI>
            <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLDIR" />
            
            <!-- Skip EULA: Redirect WelcomeDlg Next to InstallDirDlg -->
            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Order="5" Condition="1" />
            <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="5" Condition="1" />

            <Publish Dialog="MaintenanceTypeDlg" Control="ChangeButton" Event="NewDialog" Value="VerifyReadyDlg" />

            <!-- Launch the TUI on Finish for installs, repairs, and modifications -->
            <Publish Dialog="ExitDialog" 
                     Control="Finish" 
                     Event="DoAction" 
                     Value="LaunchConfig" 
                     Condition="NOT REMOVE=&quot;ALL&quot;" />
        </UI>

        <!-- Setting ARPNOMODIFY to {} (empty in SetProperty) enables the 'Modify' button in Add/Remove Programs -->
        <SetProperty Id="ARPNOMODIFY" Value="{}" After="AppSearch" Sequence="first" />
        <SetProperty Id="ARPNOREPAIR" Value="1" After="AppSearch" Sequence="first" />

        <Property Id="ARPCOMMENTS" Value="Agent to manage bare-metal OS booting via Home Assistant and WOL" />
        <Property Id="ARPCONTACT" Value="Jeremy Jack" />
        <Property Id="ARPHELPLINK" Value="https://github.com/jjack/grubstation" />
        <Property Id="ARPURLINFOABOUT" Value="https://github.com/jjack/grubstation" />
        <Property Id="ARPPRODUCTICON" Value="grubstation.ico" />

        <StandardDirectory Id="ProgramFiles6432Folder">
            <Directory Id="INSTALLDIR" Name="GrubStation" />
        </StandardDirectory>

        <StandardDirectory Id="CommonAppDataFolder">
            <Directory Id="ProgramDataGrubStation" Name="GrubStation" />
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="GrubStation"/>
        </StandardDirectory>

        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="ApplicationShortcut" Guid="*">
                <Shortcut Id="ApplicationStartMenuShortcut" 
                          Name="GrubStation Setup" 
                          Description="Configure GrubStation"
                          Target="[INSTALLDIR]grubstation.exe"
                          Arguments="setup"
                          WorkingDirectory="INSTALLDIR"
                          Icon="grubstation.ico" />
                <RemoveFolder Id="CleanUpShortCut" On="uninstall"/>
                <RegistryValue Root="HKCU" Key="Software\JeremyJack\GrubStation" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
            </Component>
        </DirectoryRef>

        <DirectoryRef Id="ProgramDataGrubStation">
            <Component Id="CleanupConfig" Guid="06e23b2c-8067-4a0b-8092-23c2186835a2">
                <!-- Ensure the folder is created with write permissions for everyone 
                     so the user-mode TUI can save the config -->
                <CreateFolder>
                    <Permission User="Everyone" GenericAll="yes" />
                </CreateFolder>
                <RemoveFile Id="RemoveConfig" Name="*" On="uninstall" />
                <RemoveFolder Id="RemoveConfigDir" On="uninstall" />
                <RegistryValue Root="HKLM" Key="Software\JeremyJack\GrubStation" Name="config_cleaned" Type="integer" Value="1" KeyPath="yes" />
            </Component>
        </DirectoryRef>

        <ComponentGroup Id="ProductComponents" Directory="INSTALLDIR">
            <Component Id="Executable" Guid="*">
                <File Id="GrubStationEXE" Name="grubstation.exe" Source="$(var.BinaryPath)" KeyPath="yes" />

                <!-- Native Windows Service Installation -->
                <ServiceInstall Id="ServiceInstall_GrubStation"
                                Type="ownProcess"
                                Name="GrubStation"
                                DisplayName="GrubStation"
                                Description="Agent to manage bare-metal OS booting via Home Assistant and WOL"
                                Start="auto"
                                Account="LocalSystem"
                                ErrorControl="normal"
                                Arguments="serve">
                    <!-- Grant Authenticated Users permission to start/stop the service
                         so the user-mode TUI can start it after setup -->
                    <util:PermissionEx User="Authenticated Users" ServiceStart="yes" ServiceStop="yes" ServiceQueryStatus="yes" />
                </ServiceInstall>

                <ServiceControl Id="ServiceControl_GrubStation" 
                                Name="GrubStation" 
                                Stop="both" 
                                Remove="uninstall" 
                                Wait="yes" />

                <!-- Program-based Firewall Exception (Port Agnostic) -->
                <!-- We set IgnoreFailure="yes" and Profile="all" to ensure the installer doesn't rollback if firewall service is tricky -->
                <fw:FirewallException Id="GrubStationFW"
                                      Name="GrubStation"
                                      Description="Allow inbound traffic for GrubStation daemon"
                                      Profile="all"
                                      IgnoreFailure="yes"
                                      File="GrubStationEXE" />
            </Component>
        </ComponentGroup>

        <!-- CUSTOM ACTION: Launch the TUI -->
        <CustomAction Id="LaunchConfig" 
                      FileRef="GrubStationEXE" 
                      ExeCommand="setup" 
                      Return="asyncNoWait" />

        <Feature Id="ProductFeature" Title="GrubStation" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentRef Id="ApplicationShortcut" />
            <ComponentRef Id="CleanupConfig" />
        </Feature>
    </Package>

    <Fragment>
        <Icon Id="grubstation.ico" SourceFile="..\..\.build\windows\grubstation.ico" />
    </Fragment>

</Wix>
